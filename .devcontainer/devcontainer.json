{
	"name": "Kapan Starknet",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:2": {},
		"ghcr.io/devcontainers/features/node:1": {},
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installWget": true,
			"installCurl": true
		}
	},
	"forwardPorts": [
		3000
	],
	"portsAttributes": {
		"3000": {
			"label": "Next.js Dev Server",
			"onAutoForward": "notify",
			"requireLocalPort": true,
			"protocol": "http",
			"elevateIfNeeded": false
		}
	},
	"mounts": [
		"source=opencode-config,target=/home/node/.config/opencode,type=volume",
		"source=opencode-data,target=/home/node/.local/share/opencode,type=volume",
		"source=claude-config,target=/home/node/.config/claude-code,type=volume",
		"source=vscode-extensions,target=/home/node/.vscode-server/extensions,type=volume",
		"source=vscode-userdata,target=/home/node/.vscode-server/data/User,type=volume",
		"source=next-cache,target=${containerWorkspaceFolder}/.next/cache,type=volume",
		"source=pnpm-store,target=/home/node/.local/share/pnpm/store,type=volume"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"NomicFoundation.hardhat-solidity",
				"StarkWare.cairo1",
				"tamasfe.even-better-toml",
				"openai.chatgpt",
				"anthropic.claude-code"
			]
		}
	},
	"postCreateCommand": "sudo mkdir -p /home/node/.local/state && sudo chown -R node:node /home/node/.local/share/opencode /home/node/.local/state /home/node/.config/opencode /home/node/.config/claude-code /home/node/.npm /home/node/.vscode-server /home/node/.local/share/pnpm 2>/dev/null || true && curl -fsSL https://opencode.ai/install | bash && npm install -g @beads/bd && echo \"alias cursor-tools='yarn cursor-tools'\" >> ~/.bashrc && echo \"alias ct='npx cursor-tools'\" >> ~/.bashrc && echo 'OpenCode + Beads + Claude Code Installed ✅'",
	"postStartCommand": "sudo chown -R node:node /home/node/.local/share/opencode /home/node/.config/opencode /home/node/.config/claude-code /home/node/.vscode-server /home/node/.local/share/pnpm 2>/dev/null || true"
}
